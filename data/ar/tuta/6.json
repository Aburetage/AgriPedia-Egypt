{
  "tab_title": "دورة الحياة",
  "content_blocks": [
    {
      "type": "doc-article",
      "items": [
        {
          "type": "doc-heading",
          "level": 1,
          "text": "الفصل السابع"
        },
        {
          "type": "doc-heading",
          "level": 1,
          "text": "دورة حياة توتا أبسولوتا"
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "مدة الجيل، عدد الأجيال والظروف المثالية للتكاثر"
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "مقدمة"
        },
        {
          "type": "doc-paragraph",
          "text": "تمر توتا أبسولوتا بتحول كامل، ولذلك تتكون دورة حياتها من أربعة أطوار رئيسية متتابعة:"
        },
        {
          "type": "doc-list",
          "items": [
            "1. البيضة.",
            "2. اليرقة، وتشمل أربعة أعمار يرقية.",
            "3. العذراء.",
            "4. الحشرة الكاملة أو العثة."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "تبدأ الدورة عندما تضع الأنثى الملقحة البيض على نبات الطماطم، ثم يفقس البيض وتخرج اليرقات التي تدخل الأنسجة النباتية وتتغذى داخل الأوراق والقمم والسيقان والثمار. وبعد اكتمال العمر اليرقي الرابع تتوقف اليرقة عن التغذية وتتحول إلى عذراء، ثم تخرج منها عثة كاملة قادرة على التزاوج وإنتاج جيل جديد."
        },
        {
          "type": "doc-paragraph",
          "text": "وتتميز دورة حياة توتا أبسولوتا بثلاث خصائص رئيسية:"
        },
        {
          "type": "doc-list",
          "items": [
            "قصر مدة الجيل في الأجواء الدافئة الملائمة.",
            "إمكانية إنتاج أجيال عديدة ومتداخلة خلال العام.",
            "استمرار التكاثر دون سكون إجباري ما دام الغذاء والحرارة المناسبة متوافرين."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "ولهذا قد توجد داخل الحقل الواحد في الوقت نفسه:"
        },
        {
          "type": "doc-list",
          "items": [
            "بيض حديث.",
            "بيض قريب من الفقس.",
            "يرقات من الأعمار الأربعة.",
            "عذارى.",
            "عثات كاملة."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "ويجعل هذا التداخل مكافحة الآفة بمعاملة واحدة أمرًا غير كافٍ؛ لأن كل طور يختلف في موقعه وحساسيته لوسائل المكافحة."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "بداية دورة الحياة"
        },
        {
          "type": "doc-paragraph",
          "text": "تبدأ دورة الحياة بعد خروج العثات الكاملة من العذارى."
        },
        {
          "type": "doc-paragraph",
          "text": "تحتاج العثة الحديثة إلى فترة قصيرة حتى:"
        },
        {
          "type": "doc-list",
          "items": [
            "تتمدد أجنحتها.",
            "يتصلب جسمها.",
            "تنضج أعضاؤها التناسلية.",
            "تبدأ نشاطها الحركي.",
            "تبحث عن شريك للتزاوج."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "تنشط العثات أساسًا خلال المساء والليل، بينما تختبئ نهارًا داخل المجموع الخضري وتحت الأوراق وفي الأماكن المظللة."
        },
        {
          "type": "doc-paragraph",
          "text": "تطلق الأنثى فرمونًا جنسيًا يجذب الذكور. وبعد حدوث التزاوج تبدأ الأنثى في وضع البيض بعد فترة ما قبل وضع البيض، التي تبلغ في الظروف الدافئة المناسبة نحو يومين في المتوسط، وقد تطول إلى أكثر من أسبوع في البرودة."
        },
        {
          "type": "doc-paragraph",
          "text": "تضع الأنثى البيض منفردًا أو في مجموعات صغيرة على الأجزاء الهوائية للنبات، خاصة الأوراق الحديثة."
        },
        {
          "type": "doc-paragraph",
          "text": "وتبلغ الخصوبة القصوى الشائعة نحو:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "260 بيضة للأنثى"
        },
        {
          "type": "doc-paragraph",
          "text": "وقد تصل في بعض الدراسات والظروف الملائمة إلى:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "250–300 بيضة للأنثى."
        },
        {
          "type": "doc-paragraph",
          "text": "لكن المتوسط الفعلي يكون أقل من الحد الأقصى، ويتغير حسب الحرارة والعائل وحجم الأنثى وتغذيتها وتاريخ تزاوجها."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "تعريف مدة دورة الحياة ومدة الجيل"
        },
        {
          "type": "doc-paragraph",
          "text": "يحدث خلط بين مصطلحي دورة التطور ومدة الجيل، رغم اختلافهما."
        },
        {
          "type": "doc-heading",
          "level": 3,
          "text": "دورة التطور من البيضة إلى الحشرة الكاملة"
        },
        {
          "type": "doc-paragraph",
          "text": "هي الفترة التي تبدأ بوضع البيضة وتنتهي بخروج العثة الكاملة من العذراء."
        },
        {
          "type": "doc-paragraph",
          "text": "وتشمل:"
        },
        {
          "type": "doc-list",
          "items": [
            "حضانة البيض.",
            "الأعمار اليرقية الأربعة.",
            "طور العذراء."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "ويُطلق عليها:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "Egg-to-adult developmental period"
        },
        {
          "type": "doc-heading",
          "level": 3,
          "text": "مدة الجيل البيولوجي"
        },
        {
          "type": "doc-paragraph",
          "text": "هي الفترة من وضع بيضة في جيل معين حتى تبدأ الأنثى الناتجة منها في وضع بيض الجيل التالي."
        },
        {
          "type": "doc-paragraph",
          "text": "وتشمل:"
        },
        {
          "type": "doc-list",
          "items": [
            "مدة البيضة.",
            "مدة اليرقة.",
            "مدة العذراء.",
            "فترة ما قبل وضع البيض."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "ولهذا تكون مدة الجيل أطول قليلًا من فترة البيضة إلى خروج الحشرة الكاملة."
        },
        {
          "type": "doc-heading",
          "level": 3,
          "text": "طول عمر الحشرة الكاملة"
        },
        {
          "type": "doc-paragraph",
          "text": "لا يدخل طول عمر العثة كاملًا في حساب بداية الجيل التالي؛ لأن الأنثى تبدأ وضع البيض قبل موتها بفترة طويلة."
        },
        {
          "type": "doc-paragraph",
          "text": "وقد تستمر الأنثى في وضع البيض عدة أيام بعد بدء الجيل الجديد، ولذلك تتداخل الأجيال بدل أن تنتهي مجموعة كاملة قبل بداية المجموعة التالية."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "التسلسل العام لدورة الحياة"
        },
        {
          "type": "doc-paragraph",
          "text": "يمكن تلخيص الدورة في الظروف الدافئة الملائمة كما يأتي:"
        },
        {
          "type": "doc-table",
          "headers": [
            "الطور",
            "المدة التقريبية المعتادة"
          ],
          "rows": [
            [
              "البيضة",
              "4–6 أيام"
            ],
            [
              "اليرقة بأعمارها الأربعة",
              "10–15 يومًا"
            ],
            [
              "العذراء",
              "6–10 أيام"
            ],
            [
              "فترة ما قبل وضع البيض",
              "1–3 أيام"
            ],
            [
              "الجيل الكامل من بيضة إلى بيضة",
              "نحو 24–35 يومًا"
            ]
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "ولا تمثل هذه المدد أرقامًا ثابتة؛ فقد يقصر الجيل إلى نحو 20 يومًا في ظروف حرارية معينة، بينما يمتد إلى أكثر من 60 يومًا خلال الشتاء والبرودة."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "مدة دورة التطور عند درجات الحرارة المختلفة"
        },
        {
          "type": "doc-paragraph",
          "text": "تتحكم درجة الحرارة بدرجة كبيرة في سرعة تطور جميع أطوار توتا أبسولوتا."
        },
        {
          "type": "doc-paragraph",
          "text": "وفي دراسة أُجريت عند درجات حرارة ثابتة، سجلت المدد الآتية:"
        },
        {
          "type": "doc-table",
          "headers": [
            "درجة الحرارة",
            "البيضة",
            "اليرقة",
            "العذراء",
            "من البيضة إلى خروج العثة"
          ],
          "rows": [
            [
              "10°م",
              "24.4 يومًا",
              "56.4 يومًا",
              "36.8 يومًا",
              "115.4 يومًا"
            ],
            [
