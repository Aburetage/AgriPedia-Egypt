              "1.9 يوم",
              "20.2 يومًا"
            ]
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "وتوضح هذه القيم أن الجيل يمكن أن يكتمل من بيضة إلى بيضة خلال نحو:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "26 يومًا عند 25°م."
        },
        {
          "type": "doc-paragraph",
          "text": "أما عند 10°م فقد يحتاج إلى أكثر من أربعة أشهر."
        },
        {
          "type": "doc-paragraph",
          "text": "ومع ذلك، لم تكن درجة 30°م في الدراسة نفسها هي الأفضل للتكاثر، رغم أنها أعطت أقصر مدة للجيل، إذ انخفضت خصوبة الإناث وحيوية البيض بشدة."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "أسرع درجة حرارة ليست دائمًا الدرجة المثالية"
        },
        {
          "type": "doc-paragraph",
          "text": "يجب التمييز بين:"
        },
        {
          "type": "doc-list",
          "items": [
            "درجة الحرارة التي تحقق أسرع نمو.",
            "درجة الحرارة التي تحقق أعلى بقاء.",
            "درجة الحرارة التي تحقق أعلى خصوبة.",
            "درجة الحرارة التي تحقق أسرع زيادة في أعداد المجتمع الحشري."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "ففي إحدى الدراسات أتمت الحشرة دورة البيضة إلى العثة خلال 18.3 يومًا عند 30°م، مقابل 23.5 يومًا عند 25°م."
        },
        {
          "type": "doc-paragraph",
          "text": "لكن عند 30°م سجلت الدراسة:"
        },
        {
          "type": "doc-list",
          "items": [
            "انخفاضًا كبيرًا في خصوبة الأنثى.",
            "انخفاضًا شديدًا في نسبة فقس البيض.",
            "قصرًا في عمر الحشرات الكاملة.",
            "تأثرًا سلبيًا في البقاء الكلي."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "أما عند 20–25°م فقد اجتمعت:"
        },
        {
          "type": "doc-list",
          "items": [
            "سرعة نمو مناسبة.",
            "ارتفاع بقاء البيض واليرقات والعذارى.",
            "ارتفاع الخصوبة.",
            "ارتفاع نسبة البيض المخصب القابل للفقس.",
            "استمرار أفضل للجيل التالي."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "ولهذا لا تُعد 30°م درجة مثالية مطلقة، حتى لو قصرت عندها مدة التطور."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "الظروف الحرارية المثالية للتكاثر"
        },
        {
          "type": "doc-paragraph",
          "text": "يقع النطاق الحراري الأكثر ملاءمة وثباتًا لتطور وتكاثر توتا أبسولوتا حول:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "20–25°م."
        },
        {
          "type": "doc-paragraph",
          "text": "وقد قدرت نماذج ديموغرافية حديثة النطاق الأمثل لبقاء الأطوار غير الكاملة وخصوبة الإناث حول:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "21–23°م."
        },
        {
          "type": "doc-paragraph",
          "text": "وتعد درجة 25°م من الدرجات شديدة الملاءمة لتطور الجيل، إذ سجلت إحدى الدراسات عندها:"
        },
        {
          "type": "doc-list",
          "items": [
            "حضانة البيض: 4.5 أيام.",
            "مدة اليرقة: 11 يومًا.",
            "مدة العذراء: 8.4 أيام.",
            "دورة البيضة إلى العثة: 23.5 يومًا.",
            "فترة ما قبل الوضع: 2.3 يوم.",
            "متوسط الخصوبة: نحو 149 بيضة للأنثى.",
            "نسبة فقس البيض: نحو 81%.",
            "بقاء اليرقات: نحو 81%.",
            "بقاء العذارى: نحو 84%."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "وتختلف الأرقام بين التجمعات والسلالات والأصناف، لكن معظم الدراسات تشير إلى أن درجات الحرارة المعتدلة الدافئة تحقق أفضل توازن بين النمو والبقاء والتكاثر."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "تأثير درجات الحرارة المنخفضة"
        },
        {
          "type": "doc-paragraph",
          "text": "تؤدي البرودة إلى إبطاء جميع عمليات النمو والتكاثر."
        },
        {
          "type": "doc-paragraph",
          "text": "وعند انخفاض الحرارة:"
        },
        {
          "type": "doc-list",
          "items": [
            "تطول مدة حضانة البيض.",
            "تطول الأعمار اليرقية.",
            "تطول مدة العذراء.",
            "تتأخر العثة في التزاوج.",
            "تطول فترة ما قبل وضع البيض.",
            "ينخفض معدل وضع البيض يوميًا.",
            "تقل حركة العثات.",
            "ينخفض عدد الأجيال السنوية."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "لكن انخفاض النشاط لا يعني اختفاء الآفة؛ إذ يمكن لبعض الأطوار البقاء خلال الشتاء، خاصة:"
        },
        {
          "type": "doc-list",
          "items": [
            "العذارى في التربة والمخلفات.",
            "البيض على النباتات.",
            "العثات في الزراعات المحمية.",
            "اليرقات داخل الأنفاق والثمار.",
            "الأطوار الموجودة على نباتات باذنجانية مستمرة."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "وقد تمتد دورة الحياة في الشتاء إلى:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "أكثر من 60 يومًا"
        },
        {
          "type": "doc-paragraph",
          "text": "وقد تتجاوز 90 يومًا في الفترات الباردة جدًا."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "تأثير الحرارة المرتفعة"
        },
        {
          "type": "doc-paragraph",
          "text": "تسرع الحرارة المرتفعة التطور حتى حد معين، ثم تبدأ آثار الإجهاد الحراري في الظهور."
        },
        {
          "type": "doc-paragraph",
          "text": "وقد تؤدي الحرارة الشديدة المستمرة إلى:"
        },
        {
          "type": "doc-list",
          "items": [
            "انخفاض فقس البيض.",
            "ارتفاع موت اليرقات الحديثة.",
            "فشل بعض الانسلاخات.",
            "موت العذارى.",
            "خروج عثات مشوهة.",
            "قصر عمر الحشرات الكاملة.",
            "انخفاض الخصوبة.",
            "انخفاض كفاءة الحيوانات المنوية.",
            "انخفاض بقاء الجيل التالي."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "ولا تعكس درجة حرارة الهواء وحدها درجة الحرارة التي تتعرض لها الآفة؛ فاليرقة داخل النفق تعيش في مناخ محلي مختلف، كما توفر الأوراق الكثيفة والري والصوب مناطق أكثر اعتدالًا من الجو الخارجي."
        },
        {
          "type": "doc-paragraph",
          "text": "ولهذا قد تستمر الإصابة خلال فترات الحرارة المرتفعة، خاصة داخل:"
        },
        {
          "type": "doc-list",
          "items": [
            "المجموع الخضري الكثيف.",
            "الأنفاق الورقية.",
            "الثمار.",
            "الطبقة السطحية من التربة.",
            "الصوب والمناطق المظللة."
          ]
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "الاحتياجات الحرارية للجيل"
        },
        {
          "type": "doc-paragraph",
          "text": "لا يعتمد تطور الحشرة على عدد الأيام فقط، بل يعتمد على كمية الحرارة المتراكمة فوق الحد الحراري الأدنى."
        },
        {
          "type": "doc-paragraph",
          "text": "وقد قُدر الحد الحراري الأدنى لدورة البيضة إلى الحشرة الكاملة بنحو:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "8°م."
        },
        {
          "type": "doc-paragraph",
          "text": "وقدرت الحرارة اللازمة لإكمال دورة البيضة إلى العثة بنحو:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "416.7 وحدة حرارية متراكمة — Degree-Days."
        },
        {
          "type": "doc-paragraph",
          "text": "كما قُدر الحد الحراري الأعلى لدورة التطور بنحو:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "37.3°م."
        },
        {
          "type": "doc-paragraph",
          "text": "ويُحسب التراكم الحراري اليومي بصورة مبسطة من العلاقة:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "الوحدات الحرارية اليومية = متوسط الحرارة اليومية − 8"
        },
        {
          "type": "doc-paragraph",
          "text": "عندما يكون المتوسط أعلى من 8°م."
        },
        {
          "type": "doc-heading",
          "level": 3,
          "text": "مثال عند متوسط 25°م"
        },
        {
          "type": "doc-paragraph",
          "text": "الوحدات الحرارية اليومية:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "25 − 8 = 17 وحدة حرارية."
        },
        {
          "type": "doc-paragraph",
          "text": "المدة النظرية لإكمال التطور:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "416.7 ÷ 17 = نحو 24.5 يومًا."
        },
        {
          "type": "doc-paragraph",
          "text": "وتقترب هذه النتيجة من مدة البيضة إلى العثة المسجلة تجريبيًا عند 25°م."
        },
        {
          "type": "doc-paragraph",
          "text": "ولا تدخل فترة ما قبل وضع البيض بالكامل في ثابت البيضة إلى الحشرة الكاملة، ولذلك تكون مدة الجيل من بيضة إلى بيضة أطول قليلًا."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "عدم وجود سكون إجباري"
        },
        {
          "type": "doc-paragraph",
          "text": "لا تدخل يرقات توتا أبسولوتا في سكون إجباري ما دام الغذاء متاحًا والظروف تسمح بالتطور."
        },
        {
          "type": "doc-paragraph",
          "text": "وتعني هذه الصفة أن الحشرة لا تحتاج إلى التوقف الموسمي الكامل عن النمو في موعد ثابت."
        },
        {
          "type": "doc-paragraph",
          "text": "فإذا توافرت:"
        },
        {
          "type": "doc-list",
          "items": [
            "نباتات طماطم حية.",
            "عوائل باذنجانية مناسبة.",
            "حرارة تسمح بالتطور.",
            "أماكن محمية."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "يمكن أن تستمر الأطوار في النمو والتكاثر خلال أجزاء طويلة من العام."
        },
        {
          "type": "doc-paragraph",
          "text": "وتظهر أهمية ذلك في:"
        },
        {
          "type": "doc-list",
          "items": [
            "الصوب المدفأة.",
            "المناطق الدافئة.",
            "العروات المتداخلة.",
            "المشاتل.",
            "النباتات المتطوعة.",
            "الحقول التي لم تُزل مخلفاتها.",
            "مناطق زراعة الطماطم طوال العام."
          ]
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "تداخل الأجيال"
        },
        {
          "type": "doc-paragraph",
          "text": "لا تتطور جميع أفراد توتا أبسولوتا في الحقل في توقيت واحد."
        },
        {
          "type": "doc-paragraph",
          "text": "فقد تدخل بعض الإناث الحقل قبل غيرها، كما يستمر وضع البيض عدة أيام، وتختلف سرعة تطور الأفراد حسب:"
        },
        {
          "type": "doc-list",
          "items": [
            "موضعها على النبات.",
            "درجة الحرارة المحلية.",
            "وقت وضع البيض.",
            "جودة الغذاء.",
            "صنف الطماطم.",
            "تعرضها للمبيدات.",
            "التطفل والافتراس."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "ولهذا تتداخل الأجيال، ويصبح من الصعب الفصل بين الجيل الأول والثاني والثالث من خلال الفحص الحقلي فقط."
        },
        {
          "type": "doc-paragraph",
          "text": "وقد توجد على النبات الواحد في الوقت نفسه:"
        },
        {
          "type": "doc-list",
          "items": [
            "بيضة حديثة.",
            "يرقة عمر أول.",
            "يرقة عمر ثالث.",
            "عذراء داخل طية ورقية.",
            "عثة كاملة مختبئة بين الأوراق."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "وهذا التداخل هو أحد أسباب الحاجة إلى برنامج إدارة مستمر، وليس معاملة موجهة إلى يوم واحد."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "عدد الأجيال سنويًا"
        },
        {
          "type": "doc-paragraph",
          "text": "تُعد توتا أبسولوتا حشرة متعددة الأجيال:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "Multivoltine insect"
        },
        {
          "type": "doc-paragraph",
          "text": "أي إنها تستطيع إنتاج عدة أجيال خلال العام."
        },
        {
          "type": "doc-paragraph",
          "text": "وفي الظروف المناسبة والمتصلة بالعائل يمكنها إنتاج:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "10–12 جيلًا سنويًا."
        },
        {
          "type": "doc-paragraph",
          "text": "وفي بعض المراجع يقدر عدد الأجيال بنحو:"
        },
        {
          "type": "doc-list",
          "items": [
            "9–10 أجيال في الطماطم الحقلية.",
            "حتى 12 جيلًا في الصوب والزراعات المستمرة.",
            "أعداد أقل في المناطق الباردة أو ذات الموسم القصير."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "ولا يعني تسجيل 12 جيلًا أن كل جيل يستغرق 30.4 يومًا بصورة ثابتة؛ فالأجيال الصيفية تكون قصيرة، بينما تطول أجيال الشتاء، كما تتداخل الأجيال فيما بينها."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "عدد الأجيال في مصر"
        },
        {
          "type": "doc-paragraph",
          "text": "تختلف أعداد الأجيال المتوقعة داخل مصر باختلاف المنطقة والحرارة والعروة الزراعية وطريقة الحساب."
        },
        {
          "type": "doc-paragraph",
          "text": "وقد قدرت دراسة اعتمدت على درجات الحرارة المسجلة خلال عام 2012 عدد الأجيال على النحو الآتي:"
        },
        {
          "type": "doc-table",
          "headers": [
            "المحافظة",
            "متوسط الحرارة السنوي",
            "متوسط مدة الجيل",
            "عدد الأجيال السنوية"
          ],
          "rows": [
            [
              "مرسى مطروح",
              "20.53°م",
              "59.6 يومًا",
              "نحو 7 أجيال"
            ],
            [
              "الجيزة",
              "22.8°م",
              "52.44 يومًا",
              "نحو 8.05 أجيال"
            ],
            [
              "قنا",
              "26.04°م",
              "43.74 يومًا",
              "نحو 9.52 أجيال"
            ]
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "وتوضح هذه القيم أن المناطق الأكثر دفئًا يمكن أن تنتج أجيالًا أكثر خلال العام."
        },
        {
          "type": "doc-paragraph",
          "text": "وقد توقعت نماذج أخرى تعتمد على وحدات حرارية مختلفة حدوث:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "11–13 جيلًا في بعض ظروف الحقول المصرية."
        },
        {
          "type": "doc-paragraph",
          "text": "ولا تمثل هذه التقديرات تناقضًا مباشرًا؛ لأنها تختلف في:"
        },
        {
          "type": "doc-list",
          "items": [
            "تعريف بداية ونهاية الجيل.",
            "الحد الحراري المستخدم.",
            "الثابت الحراري.",
            "نوع البيانات المناخية.",
            "المنطقة والسنة.",
            "استخدام متوسطات شهرية أو درجات يومية.",
            "إدخال فترة الحشرة الكاملة في الحساب أو استبعادها.",
            "توافر العائل طوال العام."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "ولهذا لا يوجد رقم واحد ثابت يصلح لجميع محافظات مصر وكل السنوات."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "عدد الأجيال داخل عروة الطماطم"
        },
        {
          "type": "doc-paragraph",
          "text": "يعتمد عدد الأجيال التي تمر داخل عروة واحدة على:"
        },
        {
          "type": "doc-list",
          "items": [
            "مدة بقاء المحصول.",
            "توقيت دخول الآفة.",
            "درجة الحرارة.",
            "وجود حقول مصابة قريبة.",
            "نجاح المكافحة.",
            "استمرار الحقل بعد نهاية الحصاد."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "ففي دورة طماطم تستمر 120 يومًا، وعند متوسط جيل يبلغ 25–30 يومًا، يمكن نظريًا مرور:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "أربعة إلى خمسة أجيال."
        },
        {
          "type": "doc-paragraph",
          "text": "لكن الإصابة قد لا تبدأ يوم الشتل، وقد تدخل العثات في منتصف الموسم، ولذلك يكون العدد الفعلي أقل أو أكثر تداخلًا."
        },
        {
          "type": "doc-paragraph",
          "text": "وفي الشتاء قد يستغرق الجيل 50–80 يومًا، فلا يمر داخل العروة سوى جيل أو جيلين كاملين، لكن استمرار الحقل لفترة طويلة يسمح بتراكم اليرقات والأطوار المختلفة."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "الرطوبة المثالية"
        },
        {
          "type": "doc-paragraph",
          "text": "تنجح توتا أبسولوتا في نطاق واسع من الرطوبة، لكنها تحقق بقاءً وتكاثرًا جيدين عندما تكون الرطوبة معتدلة."
        },
        {
          "type": "doc-paragraph",
          "text": "ويقع النطاق العملي الملائم في كثير من الدراسات والتربيات المعملية حول:"
        },
        {
          "type": "doc-heading",
          "level": 4,
          "text": "50–70% رطوبة نسبية."
        },
        {
          "type": "doc-paragraph",
          "text": "وتساعد الرطوبة المعتدلة على:"
        },
        {
          "type": "doc-list",
          "items": [
            "تقليل جفاف البيض.",
            "تحسين بقاء اليرقات الحديثة.",
            "حماية العذارى من فقد الماء.",
            "زيادة عمر العثات.",
            "توفير أنسجة نباتية غضة.",
            "تحسين نشاط بعض الأطوار."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "وقد سجلت دراسة تحت ظروف 20.5°م ورطوبة 55%:"
        },
        {
          "type": "doc-list",
          "items": [
            "فقسًا مرتفعًا للبيض.",
            "بقاءً جيدًا لليرقات.",
            "خروجًا مرتفعًا للعثات.",
            "خصوبة أعلى من ظروف 32°م ورطوبة 40%."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "لكن الرطوبة وحدها لا تحدد الأداء؛ إذ تتفاعل مع درجة الحرارة."
        },
        {
          "type": "doc-paragraph",
          "text": "فقد يكون انخفاض البقاء عند رطوبة منخفضة ناتجًا كذلك عن الحرارة المرتفعة، وليس عن الجفاف وحده."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "تأثير الرطوبة المرتفعة والمنخفضة"
        },
        {
          "type": "doc-heading",
          "level": 3,
          "text": "الرطوبة المنخفضة"
        },
        {
          "type": "doc-paragraph",
          "text": "يمكن أن تؤدي إلى:"
        },
        {
          "type": "doc-list",
          "items": [
            "جفاف البيض.",
            "انخفاض الفقس.",
            "موت اليرقات الحديثة المكشوفة.",
            "جفاف العذارى السطحية.",
            "قصر عمر العثات.",
            "انخفاض فترة وضع البيض."
          ]
        },
        {
          "type": "doc-heading",
          "level": 3,
          "text": "الرطوبة المرتفعة جدًا"
        },
        {
          "type": "doc-paragraph",
          "text": "يمكن أن تؤدي إلى:"
        },
        {
          "type": "doc-list",
          "items": [
            "زيادة نمو الفطريات.",
            "تلف بعض البيض والعذارى.",
            "زيادة الأعفان داخل الأنسجة المصابة.",
            "تغير نشاط مسببات الأمراض الحشرية.",
            "انخفاض تهوية التربة عند اقترانها بالتشبع المائي."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "وتظل الرطوبة المعتدلة مع تهوية جيدة أكثر ملاءمة من الجفاف الشديد أو البلل المستمر."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "تأثير العائل النباتي في مدة الجيل"
        },
        {
          "type": "doc-paragraph",
          "text": "الطماطم هي العائل الأكثر ملاءمة لتطور وتكاثر توتا أبسولوتا، لكن سرعة النمو تختلف بين أصناف الطماطم نفسها."
        },
        {
          "type": "doc-paragraph",
          "text": "ويتأثر الجيل بصفات النبات، ومنها:"
        },
        {
          "type": "doc-list",
          "items": [
            "سمك الورقة.",
            "صلابة البشرة.",
            "كثافة الشعيرات.",
            "الشعيرات الغدية.",
            "المحتوى النيتروجيني.",
            "المركبات الدفاعية.",
            "عمر الأوراق.",
            "حالة النبات المائية.",
            "التوازن بين النمو الخضري والثمري."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "وقد يتغير زمن التطور من البيضة إلى الحشرة الكاملة عدة أيام بين صنف وآخر."
        },
        {
          "type": "doc-paragraph",
          "text": "كما تؤثر جودة العائل في:"
        },
        {
          "type": "doc-list",
          "items": [
            "وزن العذراء.",
            "حجم الأنثى.",
            "الخصوبة.",
            "نسبة البقاء.",
            "عدد البيض.",
            "معدل الزيادة السكانية."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "ولا يكفي قصر مدة التطور وحده لتحديد أفضل عائل؛ بل تُدرس مدة الجيل مع البقاء والخصوبة معًا."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "توافر النموات الحديثة"
        },
        {
          "type": "doc-paragraph",
          "text": "تفضل الإناث وضع البيض على الأوراق والأجزاء الحديثة، كما تبدأ اليرقات في أنسجة طرية يسهل اختراقها."
        },
        {
          "type": "doc-paragraph",
          "text": "ولهذا تساعد النباتات ذات النمو الخضري المستمر على:"
        },
        {
          "type": "doc-list",
          "items": [
            "زيادة مواقع وضع البيض.",
            "تحسين بقاء اليرقات الحديثة.",
            "استمرار انتقال اليرقات بين الأوراق والقمم.",
            "توفير غذاء متجدد.",
            "دعم الأجيال المتتابعة."
          ]
        },
        {
          "type": "doc-paragraph",
          "text": "وقد يؤدي الإفراط في التسميد النيتروجيني إلى إنتاج نموات غضة وكثيفة، مما يزيد ملاءمة النبات للآفة ويوفر أماكن مظللة لاختباء العثات."
        },
        {
          "type": "doc-paragraph",
          "text": "ولا يعني ذلك أن تقليل النيتروجين وحده يكافح التوتا، بل يعني أن التسميد المتوازن جزء من خفض ملاءمة البيئة للإصابة."
        },
        {
          "type": "doc-heading",
          "level": 2,
          "text": "أثر تداخل العروات الزراعية"
        },
        {
          "type": "doc-paragraph",
          "text": "يُعد تداخل العروات من أهم أسباب استمرار دورة الحياة."
        },
        {
          "type": "doc-paragraph",
          "text": "فقد توجد في منطقة واحدة:"
        },
        {
          "type": "doc-list",
          "items": [
            "مشاتل جديدة.",
            "حقول حديثة الشتل.",
            "حقول في النمو الخضري.",
            "حقول مثمرة.",
            "حقول انتهى حصادها.",
            "مخلفات لم تُزل."
          ]
        },
        {
          "type": "doc-paragraph",
